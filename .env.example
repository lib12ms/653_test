# NLK OpenAPI — 앱 본선 파이프라인에서는 사용하지 않음(probe_nlk_isbns.py 등 전용)
NLK_API_KEY=
NLK_ENABLE=false

# KPIPA 출판유통통합전산망 getBookDetail — ONIX 목차(TextType 04)만 알라딘 메타에 병합
# 운영: https://bnk.kpipa.or.kr/api/openApi/metaInfoSvc/getBookDetail?apiKey=...&isbn=...
# 개발 베이스 URL 예: http://49.254.92.151:8092
KPIPA_API_KEY=
KPIPA_API_BASE_URL=https://bnk.kpipa.or.kr
KPIPA_ENABLE=false

OPENAI_API_KEY=
ALADIN_TTB_KEY=

# Optional
OPENAI_MODEL=gpt-4o
# 로컬: http://127.0.0.1:8000 / 배포(Render 등): https://six53-test.onrender.com
I2M_653_API_BASE=http://127.0.0.1:8000
I2M_653_HTTP_TIMEOUT=60
