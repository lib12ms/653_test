# Streamlit 실행 시 이 파일을 `.streamlit/secrets.toml` 로 복사한 뒤 값을 맞추세요.
# cp .streamlit/secrets.toml.example .streamlit/secrets.toml   (Unix)
# copy .streamlit\secrets.toml.example .streamlit\secrets.toml   (Windows)

# 기존 gpt-4o 버전(six53-test)과 별도 비교용 배포이므로 다른 서비스 URL을 가리켜야 함.
# 로컬 테스트 시에는 아래처럼 로컬 백엔드를 가리키면 됨.
BACKEND_URL = "http://127.0.0.1:8000"
